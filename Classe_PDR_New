                    camion_le_plus_proche.demander(g.noeuds[dest].id_carg, g.noeuds[dest].quantite,"colis")
                    g.demandes.remove(dest)
                else :
                    camions_libres.remove(camion_le_plus_proche)
                
        if len(g.demandes) != 0:
            print(f"!!! [SURCHARGE] {len(g.demandes)} requêtes en attente : {g.demandes} !!!")
                
        for camion in flotte:
            camion.faire_un_tour(g)
            
        tour_actuel += 1
        
        if tour_actuel > 250: 
            print("Limite de tours atteinte.")
            break
            
    print("\n--- FIN DE LA SIMULATION ---")
