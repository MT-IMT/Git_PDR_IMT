class Noeud:
    """Représente un nœud (sommet) du graphe."""
    def __init__(
        self,
        identifiant,
        nom,
        x: float,
        y: float,
        time_window: tuple[float, float],
        quantite: float = 0.0,
        heure_apparition: float = 0.0
    ):
        self.id = identifiant
        self.nom = nom
        self.x = x
        self.y = y
        self.time_window = time_window          # (heure_ouverture, heure_fermeture)
        self.requete_presente = True            # True si une demande est active
        self.quantite = quantite
        self.statut = "en_attente"              # "en_attente", "servi", "en_cours_livraison"
        self.heure_apparition = heure_apparition

    def __repr__(self):
        return f"Noeud({self.id})"

    def __str__(self):
        return str(self.id)


class Arete:
    """Représente une arête (lien) entre deux nœuds."""
    def __init__(self, source, cible, poids=1.0, **attributs):
        self.source = source
        self.cible = cible
        self.poids = poids
        self.attributs = attributs

    def __repr__(self):
        return f"Arete({self.source} -> {self.cible}, poids={self.poids})"


class Graphe:
    """Graphe orienté ou non, avec liste d'adjacence."""
    def __init__(self, oriente=False):
        self.oriente = oriente
        self.noeuds = {}         # identifiant -> objet Noeud
        self.aretes = []         # liste de toutes les arêtes
        self.adjacence = {}      # identifiant_source -> liste de (identifiant_cible, arete)
        self.demandes = []

    def ajouter_noeud(self, noeud):
        """Ajoute un nœud au graphe."""
        if noeud.id in self.noeuds:
            raise ValueError(f"Un nœud avec l'id {noeud.id} existe déjà.")
        self.noeuds[noeud.id] = noeud
        self.adjacence[noeud.id] = []

    def obtenir_noeud(self, identifiant):
        """Retourne l'objet Noeud correspondant à l'identifiant."""
        return self.noeuds.get(identifiant)

    def ajouter_arete(self, source_id, cible_id, poids=1.0, **attributs):
        """Ajoute une arête entre deux nœuds."""
        if source_id not in self.noeuds:
            raise ValueError(f"Le nœud source {source_id} n'existe pas.")
        if cible_id not in self.noeuds:
            raise ValueError(f"Le nœud cible {cible_id} n'existe pas.")

        source = self.noeuds[source_id]
        cible = self.noeuds[cible_id]

        arete = Arete(source, cible, poids, **attributs)
        self.aretes.append(arete)
        self.adjacence[source_id].append((cible_id, arete))

        if not self.oriente:
            arete_inverse = Arete(cible, source, poids, **attributs)
            self.aretes.append(arete_inverse)
            self.adjacence[cible_id].append((source_id, arete_inverse))

    def voisins(self, noeud_id):
        """Retourne la liste des voisins d'un nœud."""
        return self.adjacence.get(noeud_id, [])

    def poids_arete(self, source_id, cible_id):
        """Retourne le poids de l'arête entre source et cible."""
        for cid, arete in self.adjacence.get(source_id, []):
            if cid == cible_id:
                return arete.poids
        return None

    def construire_demandes(self):
        """Remplit la liste des demandes à partir des sommets actifs."""
        self.demandes = []
        for s in self.noeuds.values():
            if s.requete_presente:
                self.demandes.append({
                    "nom": s.id,
                    "coordonnees": (s.x, s.y),
                    "time_window": s.time_window,
                    "heure_apparition": s.heure_apparition
                })

    def dijkstra(self, depart_id, arrivee_id):
        """
        Calcule le plus court chemin entre deux sommets.
        Retourne (chemin, distance_totale).
        """
        from heapq import heappush, heappop

        if depart_id not in self.noeuds or arrivee_id not in self.noeuds:
            return [], float("inf")

        distances = {nid: float("inf") for nid in self.noeuds}
        precedent = {nid: None for nid in self.noeuds}
        distances[depart_id] = 0

        tas = [(0, depart_id)]

        while tas:
            dist_courante, u = heappop(tas)

            if dist_courante > distances[u]:
                continue

            if u == arrivee_id:
                break

            for v, arete in self.voisins(u):
                nouvelle_dist = dist_courante + arete.poids
                if nouvelle_dist < distances[v]:
                    distances[v] = nouvelle_dist
                    precedent[v] = u
                    heappush(tas, (nouvelle_dist, v))

        if distances[arrivee_id] == float("inf"):
            return [], float("inf")

        chemin = []
        courant = arrivee_id
        while courant is not None:
            chemin.append(courant)
            courant = precedent[courant]
        chemin.reverse()

        return chemin, distances[arrivee_id]

    def __repr__(self):
        return f"Graphe(oriente={self.oriente}, {len(self.noeuds)} nœuds, {len(self.aretes)} arêtes)"


class Camion:
    """Classe indépendante représentant un camion pouvant se déplacer sur un graphe."""
    def __init__(self, identifiant, capacite, position_depart):
        self.id = identifiant
        self.capacite = capacite
        self.disponible = True
        self.demandes_assignees = []
        self.position = position_depart
        self.cible_actuelle = None
        self.charge_actuelle = 0
        self.cargaison = {}
        self.route = []
        self.temps_restant_deplacement = 0.0

    def charger(self, id_cargaison, poids_marchandise, marchandise):
        """Charge une marchandise si la capacité le permet."""
        if self.charge_actuelle + poids_marchandise > self.capacite:
            raise ValueError("Capacité insuffisante pour charger ce poids.")
        self.charge_actuelle += poids_marchandise
        self.cargaison[id_cargaison] = [poids_marchandise, marchandise]
        print(f"Camion {self.id} : chargé {poids_marchandise} kg. Charge totale = {self.charge_actuelle}")

    def decharger(self, id_cargaison):
        """Décharge une marchandise."""
        if id_cargaison not in self.cargaison:
            raise ValueError("Cette cargaison n'existe pas.")
        marchandise = self.cargaison.pop(id_cargaison)
        self.charge_actuelle -= marchandise[0]
        print(f"Camion {self.id} : déchargé {marchandise[0]} kg. Charge restante = {self.charge_actuelle}")

    def assigner_demande(self, graphe, destination):
        """Assigne une nouvelle demande au camion et calcule la route."""
        if self.cible_actuelle is not None or self.route:
            print(f"Camion {self.id} occupé, impossible d'assigner une nouvelle demande.")
            return

        self.demandes_assignees.append(destination)
        self.route = self.trouver_chemin_vers(destination, graphe)

        if self.route:
            self.disponible = False
            graphe.noeuds[destination].statut = "en_attente"
        else:
            print(f"Camion {self.id} : impossible d'atteindre {destination}.")

    def definir_itineraire(self, chemin):
        """Définit la liste des nœuds à parcourir."""
        self.route = chemin[:]
        print(f"Camion {self.id} : nouvel itinéraire défini : {self.route}")

    def avancer(self, graphe):
        """Avance d'un pas le long de l'itinéraire."""
        if not self.route:
            print(f"Camion {self.id} : déjà à destination ou aucun itinéraire.")
            return False

        prochain_noeud = self.route[0]
        poids = graphe.poids_arete(self.position, prochain_noeud)
        if poids is None:
            print(f"Erreur : pas d'arête directe de {self.position} vers {prochain_noeud}.")
            return False

        self.position = prochain_noeud
        self.route.pop(0)
        print(f"Camion {self.id} : arrivé au nœud {self.position}")
        return True

    def trouver_chemin_vers(self, destination, graphe):
        """
        Utilise Dijkstra pour trouver un itinéraire.
        Met à jour self.route avec le chemin trouvé (sans inclure la position actuelle).
        """
        chemin, distance = graphe.dijkstra(self.position, destination)

        if not chemin:
            print(f"Camion {self.id} : aucun chemin vers {destination}.")
            self.route = []
            return self.route

        if chemin[0] == self.position:
            self.route = chemin[1:]
        else:
            self.route = chemin

        print(f"Camion {self.id} : chemin trouvé vers {destination} : {self.route} (distance = {distance})")
        return self.route

    def faire_un_tour(self, graphe):
        """
        Exécute un tour de simulation pour le camion.
        Gère le transit sur les arêtes en fonction de leur poids.
        """
        # CAS 1 : le camion est déjà en transit
        if self.cible_actuelle is not None:
            self.temps_restant_deplacement -= 1

            if self.temps_restant_deplacement <= 0:
                self.position = self.cible_actuelle
                self.cible_actuelle = None
                print(f"[Tour] Camion {self.id} est ARRIVÉ au nœud {self.position}.")

                noeud_arrivee = graphe.noeuds[self.position]
                noeud_arrivee.requete_presente = False
                noeud_arrivee.statut = "servi"

                if not self.route:
                    self.disponible = True
            else:
                print(
                    f"[Tour] Camion {self.id} est en route vers {self.cible_actuelle} "
                    f"(reste {self.temps_restant_deplacement} tours)."
                )
            return

        # CAS 2 : le camion est sur un nœud et doit partir
        if self.route:
            prochain_noeud = self.route.pop(0)
            poids = graphe.poids_arete(self.position, prochain_noeud)

            if poids is None:
                print(f"Erreur : pas d'arête directe de {self.position} vers {prochain_noeud}.")
                self.route = []
                self.disponible = True
                return

            self.cible_actuelle = prochain_noeud
            self.temps_restant_deplacement = poids - 1
            print(
                f"[Tour] Camion {self.id} QUITTE le nœud {self.position} "
                f"en direction de {self.cible_actuelle}. (Distance totale : {poids})"
            )

            self.position = None
            self.disponible = False

            # Cas particulier : arrivée immédiate
            if self.temps_restant_deplacement <= 0:
                self.position = self.cible_actuelle
                self.cible_actuelle = None
                print(f"[Tour] Camion {self.id} est ARRIVÉ au nœud {self.position}.")

                noeud_arrivee = graphe.noeuds[self.position]
                noeud_arrivee.requete_presente = False
                noeud_arrivee.statut = "servi"

                if not self.route:
                    self.disponible = True

        # CAS 3 : le camion attend
        else:
            self.disponible = True
            print(f"[Tour] Camion {self.id} est en attente au nœud {self.position}.")

    def __repr__(self):
        return f"Camion({self.id}, capacité={self.capacite}, position={self.position})"


def distance_entre(graphe, depart, arrivee):
    """Calcule la distance la plus courte entre deux nœuds sans modifier les camions."""
    if depart == arrivee:
        return 0

    _, distance = graphe.dijkstra(depart, arrivee)
    return distance


if __name__ == "__main__":
    # --- 1. CRÉATION DU GRAPHE (Grande ville en grille 4x4) ---
    g = Graphe(oriente=False)

    # Création des camions
    camion1 = Camion("Camion-01", capacite=20, position_depart=0)
    camion2 = Camion("Camion-02", capacite=20, position_depart=0)

    # Ajout de 16 nœuds (A à P)
    noeuds_data = [
        (0, "A", 0, 0),   (1, "B", 5, 0),   (2, "C", 10, 0),  (3, "D", 15, 0),
        (4, "E", 0, 5),   (5, "F", 5, 5),   (6, "G", 10, 5),  (7, "H", 15, 5),
        (8, "I", 0, 10),  (9, "J", 5, 10),  (10, "K", 10, 10), (11, "L", 15, 10),
        (12, "M", 0, 15), (13, "N", 5, 15), (14, "O", 10, 15), (15, "P", 15, 15)
    ]

    for id_n, nom, x, y in noeuds_data:
        g.ajouter_noeud(Noeud(id_n, nom, x, y, (0, 0), 100))

    # Ajout automatique des arêtes pour créer la grille
    for i in range(4):
        for j in range(4):
            noeud_actuel = i * 4 + j
            if j < 3:
                g.ajouter_arete(noeud_actuel, noeud_actuel + 1, poids=3)
            if i < 3:
                g.ajouter_arete(noeud_actuel, noeud_actuel + 4, poids=4)

    # Quelques rocades rapides
    g.ajouter_arete(5, 10, poids=5)
    g.ajouter_arete(6, 9, poids=5)
    g.ajouter_arete(0, 5, poids=5)
    g.ajouter_arete(10, 15, poids=5)

    # --- 2. CRÉATION DE LA FLOTTE ---
    flotte = [camion1, camion2]

    # --- 3. GESTION DYNAMIQUE DES DEMANDES ---
    demandes_futures = {
        2: [0, 15],
        5: [3, 12, 7],
        8: [1, 14, 2, 11],
        15: [4, 9, 6, 8],
        20: [5, 10]
    }

    demandes_en_attente = []

    print("\n--- DÉBUT DE LA SIMULATION (MODE SURCHARGE) ---")
    tour_actuel = 1

    while any(c.route or c.cible_actuelle is not None for c in flotte) or demandes_futures or demandes_en_attente:
        print(f"\n--- TOUR {tour_actuel} ---")

        # 1. Apparition des nouvelles demandes
        if tour_actuel in demandes_futures:
            nouvelles_destinations = demandes_futures.pop(tour_actuel)
            print(f">>> [ALERTE] Nouvelles demandes apparues pour les destinations : {nouvelles_destinations} ! <<<")
            demandes_en_attente.extend(nouvelles_destinations)

        # 2. Dispatcher intelligent
        demandes_non_assignees = []
        for dest in demandes_en_attente:
            camions_libres = [c for c in flotte if not c.route and c.cible_actuelle is None and c.position is not None]

            if camions_libres:
                camion_le_plus_proche = min(camions_libres, key=lambda c: distance_entre(g, c.position, dest))
                print(f"--> [DISPATCH] Assignation de la demande vers {dest} au {camion_le_plus_proche.id} (le plus proche)")
                camion_le_plus_proche.trouver_chemin_vers(dest, g)
                camion_le_plus_proche.disponible = False
            else:
                demandes_non_assignees.append(dest)

        if demandes_non_assignees:
            print(f"!!! [SURCHARGE] {len(demandes_non_assignees)} requêtes en attente : {demandes_non_assignees} !!!")

        demandes_en_attente = demandes_non_assignees

        # 3. Faire avancer les camions
        for camion in flotte:
            camion.faire_un_tour(g)

        tour_actuel += 1

        if tour_actuel > 250:
            print("Limite de tours atteinte.")
            break

    print("\n--- FIN DE LA SIMULATION ---")
