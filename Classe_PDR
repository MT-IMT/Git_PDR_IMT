class Noeud:
    """Représente un nœud (sommet) du graphe."""
    def __init__(self, identifiant, nom, x: float, y: float, time_window: tuple[float, float],
                 quantite: float = 0.0, heure_apparition: float = 0.0):
        """
        :param identifiant: identifiant unique du nœud (str ou int)
        :param donnees: attributs supplémentaires (par exemple, nom, coordonnées)
        """
        self.id = identifiant
        self.nom = nom
        self.x = x
        self.y = y
        self.time_window = time_window          # (heure_ouverture, heure_fermeture)
        self.requete_presente = False            # True si une demande est active
        self.quantite = quantite                 # nombre de personnes ou marchandise
        self.id_carg = 0
        self.statut = "en_attente"               # "en_attente", "servi", "en_cours_livraison"
        self.heure_apparition = heure_apparition # heure à laquelle la demande apparaît

    def __repr__(self):
        return f"Noeud({self.id})"

    def __str__(self):
        return str(self.id)


class Arete:
    """Représente une arête (lien) entre deux nœuds."""
    def __init__(self, source, cible, poids=1.0, **attributs):
        """
        :param source: nœud de départ (objet Noeud)
        :param cible: nœud d'arrivée (objet Noeud)
        :param poids: poids / coût de l'arête (par défaut 1.0)
        :param attributs: attributs supplémentaires (par exemple, distance, temps, nom de rue)
        """
        self.source = source
        self.cible = cible
        self.poids = poids
        self.attributs = attributs

    def __repr__(self):
        return f"Arete({self.source} -> {self.cible}, poids={self.poids})"


class Graphe:
    """Graphe orienté ou non, avec liste d'adjacence."""
    def __init__(self, oriente=False):
        """
        :param oriente: True si le graphe est orienté, False sinon (par défaut non orienté)
        """
        self.oriente = oriente #on verra si on oriente le graphe ou pas
        self.noeuds = {}        # identifiant -> objet Noeud
        self.aretes = []         # liste de toutes les arêtes (objets Arete)
        self.adjacence = {}      # identifiant_source -> liste de (identifiant_cible, arete)
        self.demandes = []            # liste des demandes sous forme de liste d'id de noeud

    def ajouter_noeud(self, noeud):
        """Ajoute un nœud au graphe."""
        if noeud.id in self.noeuds:
            raise ValueError(f"Un nœud avec l'id {noeud.id} existe déjà.")
        self.noeuds[noeud.id] = noeud
        self.adjacence[noeud.id] = []

    def obtenir_noeud(self, identifiant):
        """Retourne l'objet Noeud correspondant à l'identifiant."""
        return self.noeuds.get(identifiant)

    def ajouter_arete(self, source_id, cible_id, poids, **attributs):
        """
        Ajoute une arête entre deux nœuds (identifiés par leurs id).
        Si le graphe n'est pas orienté, ajoute également l'arête inverse.
        """
        if source_id not in self.noeuds:
            raise ValueError(f"Le nœud source {source_id} n'existe pas.")
        if cible_id not in self.noeuds:
            raise ValueError(f"Le nœud cible {cible_id} n'existe pas.")

        source = self.noeuds[source_id]
        cible = self.noeuds[cible_id]

        arete = Arete(source, cible, poids, **attributs)
        self.aretes.append(arete)

        self.adjacence[source_id].append((cible_id, arete))

        if not self.oriente:
            # Ajouter l'arête dans l'autre sens
            arete_inverse = Arete(cible, source, poids, **attributs)
            self.aretes.append(arete_inverse)
            self.adjacence[cible_id].append((source_id, arete_inverse))

    def voisins(self, noeud_id):
        """Retourne la liste des identifiants des voisins d'un nœud."""
        return [(cid, arete) for cid, arete in self.adjacence.get(noeud_id, [])]

    def poids_arete(self, source_id, cible_id):
        """Retourne le poids de l'arête entre source et cible (ou None si pas d'arête directe)."""
        for cid, arete in self.adjacence.get(source_id, []):
            if cid == cible_id:
                return arete.poids
        return None

#Section expérimentale
    def construire_demandes(self):
        """Remplit la liste des demandes à partir des sommets actifs."""
        self.demandes = []
        for s in self.noeuds.values():
            if s.requete_presente:
                self.demandes.append({
                    "nom": s.id,
                    "coordonnees": (s.x, s.y),
                    "time_window": s.time_window,
                    "heure_apparition": s.heure_apparition
                })

# Fin Section Expérimentale
    def __repr__(self):
        return f"Graphe({self.oriente=}, {len(self.noeuds)} nœuds, {len(self.aretes)} arêtes)"


class Camion:
    """Classe indépendante représentant un camion pouvant se déplacer sur un graphe."""
    def __init__(self, identifiant, capacite, position_depart):
        """
        :param identifiant: identifiant unique du camion
        :param capacite: capacité maximale de chargement (en tonnes, volume, etc.)
        :param position_depart: identifiant du nœud de départ
        """
        self.id = identifiant
        self.capacite = capacite
        self.disponible = True                    # True = disponible, False = en livraison
        self.demandes_assignees= []  # liste des sommets à visiter
        self.position = position_depart    # id du nœud actuel
        self.destination = None
        self.cible_actuelle = None
        self.id_livr_en_cours = 0
        self.charge_actuelle = capacite            # charge courante
        self.cargaison = {}                  # dictionnaire des marchandises, l'identifiant de la marchandise est associer à la marchandise (peut être une liste d'objets)
        self.route = []                       # liste d'identifiants de nœuds à suivre (itinéraire)
        self.temps_restant  = 0.0      # temps avant d'arriver au prochain sommet
        self.boite_reception = []
        self.file_destinations = []      # Nouveau : file d'attente des destinations
        self.noeud_depot = position_depart  # Nouveau : mémorisation du dépôt

    def demander(self, id_cargaison, poids_marchandise, marchandise):
        """Réserve une marchandise pour le client si la capacité le permet."""
        self.cargaison[id_cargaison] = [poids_marchandise,marchandise]
        print(f"Camion {self.id} : a reçu une demande de {poids_marchandise} kg. Charge restante = {self.charge_actuelle}")

    def recharger(self):
        """Charge une marchandise si la capacité le permet."""
        if self.charge_actuelle  >= self.capacite:
            raise ValueError("Camion déjà chargé")
        poid_rajouter = self.capacite - self.charge_actuelle
        self.charge_actuelle = self.capacite 
        print(f"Camion {self.id} : chargé {poid_rajouter} kg. Charge totale = {self.charge_actuelle}")

    def decharger(self, id_cargaison):
        """Décharge une marchandise"""
        if not self.cargaison:
            raise ValueError(f"Cargaison {id_cargaison} introuvable dans le camion.")
        # Retire le dernier élément pour l'exemple
        dernier = self.cargaison.pop(id_cargaison)
        self.charge_actuelle -= dernier[0]
        print(f"Camion {self.id} : déchargé {dernier[0]} kg. Charge restante = {self.charge_actuelle}")

#Section Expérimentale

    def assigner_demande(self, graphe, destination):
        """Assigne une nouvelle demande au camion et calcule la route."""
        if not self.disponible:
            print("Camion occupé, impossible d'assigner une nouvelle demande.")
            return
        self.demandes_assignees.append(destination)
        self.route = self.trouver_chemin_vers(destination, graphe)
        self.disponible = False
        graphe.noeuds[destination].statut = "en_cours_de_livraison"
        self._demarrer_deplacement(graphe)
        
    def _demarrer_deplacement(self, graphe):
        """Initialise le déplacement vers le premier sommet de la route."""
        if not self.route:
            # Aucun déplacement nécessaire (déjà sur place)
            self._arriver_a_destination(graphe)
            return
        noeud_act = self.position
        id_pro_noeud = self.route[0]
        temps = graphe.adjacence[noeud_act][0][1].poids
        for i in range(len(graphe.adjacence[noeud_act])) :
            tuple_noeud_suiv = graphe.adjacence[noeud_act][i]
            if tuple_noeud_suiv[0] == id_pro_noeud:
                temps = tuple_noeud_suiv[1].poids
        self.temps_restant  = temps

    def mettre_a_jour(self, dt: float, graphe):
        """
        Met à jour la position du camion après un intervalle de temps dt.
        À appeler à chaque pas de simulation.
        """
        if self.disponible or self.temps_restant  <= 0:
            return

        self.temps_restant  -= dt
        if self.temps_restant  <= 0:
            # Arrivée au sommet suivant
            prochain_idx = self.route[0]
            self.position = prochain_idx
            self.route.pop(0)
            if self.route:
                # Continuer vers le sommet suivant
                noeud_act = self.position
                id_pro_noeud = self.route[0]
                temps = graphe.adjacence[noeud_act][0][1].poids
                for i in range(len(graphe.adjacence[noeud_act])) :
                    tuple_noeud_suiv = graphe.adjacence[noeud_act][i]
                    if tuple_noeud_suiv[0] == id_pro_noeud:
                        temps = tuple_noeud_suiv[1].poids
                self.temps_restant = temps
                self._demarrer_deplacement(graphe)
            else:
                # Tous les sommets de la route ont été visités
                self._arriver_a_destination(graphe)

    def _arriver_a_destination(self, graphe):
        """Action effectuée quand le camion atteint le dernier sommet de sa mission."""
        # Traiter la demande (marquer comme effectuée, etc.)
        sommet_servi = graphe.noeuds[self.position]
        if sommet_servi.requete_presente :
            sommet_servi.requete_presente = False
            sommet_servi.statut = "servi"
            print(f"Camion {self.id} a servi le sommet {sommet_servi.nom}")
            self.disponible = True
            self.charge_actuelle -= sommet_servi.quantite
            self.verifier_camion_vide(graphe)
        if sommet_servi.id != 0 :
            self.disponible = True
            if self.charge_actuelle != self.capacite :
                self.recharger()
        

    def verifier_camion_vide(self, graphe) :
        en_capacite_livrer = False
        nomb_dem = len(graphe.demandes)
        for i in range(nomb_dem) :
            id_noeud = graphe.demandes[i]
            if self.charge_actuelle < graphe.noeuds[id_noeud].quantite :
                en_capacite_livrer = True
        if not en_capacite_livrer:
            self.assigner_demande(graphe,0)
            self.trouver_chemin_vers(0, graphe)
            self.recharger()
        
    def recevoir_message(self, message):
        if not hasattr(self, 'messages_recus'):
            self.messages_recus = []
        self.boite_reception.append(message)

    def traiter_messages(self, graphe, tour_actuel):
        reponses = []

        if not hasattr(self, 'messages_recus'):
            self.messages_recus = []

        for message in self.boite_reception:

            if message.type == "demande":
                demande_id = message.contenu

                cout = self.calcul_surcout(self, graphe, demande_id, tour_actuel)

                reponses.append({
                    "type": "offre",
                    "demande": demande_id,
                    "camion": self,
                    "cout": cout
                })

        self.boite_reception.clear()
        return reponses

    def calcul_surcout(self,camion, graphe, destination, tour_actuel):
        """
        Calcule le surcoût d'envoyer un camion vers une demande.
        - temps de trajet = somme des poids des arêtes
        - pénalisation si arrivée après la fin de la time_window
        """
        # Temps nécessaire pour atteindre la destination
        temps_trajet = distance_entre(graphe, camion.position, destination)
        if temps_trajet == float("inf"):
            return float("inf")  # pas de chemin

        sommet = graphe.noeuds[destination]

        # Pénalisation si le camion arriverait après la fin de la fenêtre
        penalite_temps = 0
        if tour_actuel + temps_trajet > sommet.time_window[1]:
            penalite_temps = (tour_actuel + temps_trajet - sommet.time_window[1]) * 10

        # Surcoût = temps de trajet + pénalité
        surcout = temps_trajet + penalite_temps

        return surcout
    
    def insertion_demande_centralisee(self, graphe, destination, index_insertion=None):
        """Assigne une nouvelle demande en l'insérant au meilleur endroit de la file."""
        if index_insertion is None or index_insertion >= len(self.file_destinations):
            self.file_destinations.append(destination)
        else:
            self.file_destinations.insert(index_insertion, destination)
            
        graphe.noeuds[destination].statut = "assigne"

        # Si le camion était à l'arrêt, on le fait démarrer tout de suite
        if self.disponible:
            self.passer_a_la_prochaine_destination(graphe)

    def evaluer_meilleure_insertion(self, graphe, nouvelle_dest):
        """
        Teste l'insertion de la nouvelle destination à chaque position possible de la tournée.
        Retourne un tuple : (meilleur_index_insertion, cout_supplementaire)
        """
        ancre = self.destination if self.destination is not None else self.position
        if ancre is None:
            return 0, float('inf') 
            
        sequence = [ancre] + self.file_destinations
        meilleur_surcout = float('inf')
        meilleur_index = 0
        
        for i in range(len(sequence)):
            noeud_prec = sequence[i]
            
            if i < len(sequence) - 1:
                noeud_suiv = sequence[i+1]
                cout_avec_detour = distance_entre(graphe, noeud_prec, nouvelle_dest) + distance_entre(graphe, nouvelle_dest, noeud_suiv)
                cout_trajet_initial = distance_entre(graphe, noeud_prec, noeud_suiv)
                surcout = cout_avec_detour - cout_trajet_initial
            else:
                surcout = distance_entre(graphe, noeud_prec, nouvelle_dest)
                
            if surcout < meilleur_surcout:
                meilleur_surcout = surcout
                meilleur_index = i 
                
        return meilleur_index, meilleur_surcout
    
    def passer_a_la_prochaine_destination(self, graphe):
        """Prend la prochaine destination dans la file et calcule la route."""
        if not self.file_destinations:
            self.disponible = True
            self.destination = None
            print(f"Camion {self.id} a terminé sa tournée. En attente au nœud {self.position}.")
            return
        
        prochaine_dest = self.file_destinations.pop(0)
        self.disponible = False
        self.route = self.trouver_chemin_vers(prochaine_dest, graphe)
        graphe.noeuds[prochaine_dest].statut = "en_cours_de_livraison"
        self._demarrer_deplacement(graphe)

    def _arriver_a_destination_centraliser(self, graphe):
        """Action effectuée quand le camion atteint un sommet de sa file d'attente (Version Avancée)."""
        if self.position == self.noeud_depot : # Gestion du Dépôt 
            self.charge_actuelle = self.capacite
            print(f"+++ [DÉPÔT] Camion {self.id} a refait le plein ! (Stock: {self.charge_actuelle}/{self.capacite}) +++")
            if not graphe.noeuds[self.position].requete_presente:
                self.passer_a_la_prochaine_destination(graphe)
                return

        sommet_servi = graphe.noeuds[self.position]
        
        if sommet_servi.requete_presente:
            sommet_servi.requete_presente = False
            sommet_servi.statut = "servi"
            self.charge_actuelle -= sommet_servi.quantite
            print(f" Camion {self.id} a livré {sommet_servi.nom}. Stock restant : {self.charge_actuelle}/{self.capacite} kg")

        self.passer_a_la_prochaine_destination(graphe)

    def faire_un_tour_centraliser(self, graphe):
        """Moteur de déplacement alternatif pour gérer le multi-arrêts (Version Avancée)."""
        if self.cible_actuelle is not None:
            self.temps_restant -= 1
            if self.temps_restant <= 0:
                self.position = self.cible_actuelle
                self.cible_actuelle = None
                print(f"[Tour] Camion {self.id} est ARRIVÉ au nœud {self.position}.")
                if self.position == self.destination:
                    self._arriver_a_destination_centraliser(graphe)
            else:
                print(f"[Tour] Camion {self.id} est en route vers {self.cible_actuelle} (reste {self.temps_restant} tours).")
            return

        if self.route:
            prochain_noeud = self.route.pop(0)
            poids = graphe.poids_arete(self.position, prochain_noeud)

            if poids is None:
                self.route = []
                return

            self.cible_actuelle = prochain_noeud
            self.temps_restant = poids - 1 
            print(f"[Tour] Camion {self.id} QUITTE le nœud {self.position} en direction de {self.cible_actuelle}. (Distance totale : {poids})")
            self.position = None 
            
            if self.temps_restant <= 0:
                self.position = self.cible_actuelle
                self.cible_actuelle = None
                print(f"[Tour] Camion {self.id} est ARRIVÉ au nœud {self.position}.")
                if self.position == self.destination:
                    self._arriver_a_destination_centraliser(graphe)
        else:
            print(f"[Tour] Camion {self.id} est en attente au nœud {self.position}.")

