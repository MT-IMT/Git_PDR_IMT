if __name__ == "__main__" :
    g, flotte, demandes_futures = graphe_exemple()

    print("\n--- DÉBUT DE LA SIMULATION (MODE SURCHARGE) ---")
    tour_actuel = 1
    
    while any(c.route or c.cible_actuelle is not None for c in flotte) or demandes_futures or g.demandes:
        id_carg = 1
        print(f"\n--- TOUR {tour_actuel} ---")
        
        # 1. APPARITION DES NOUVELLES DEMANDES
        if tour_actuel in demandes_futures:
            nouvelles_destinations = demandes_futures.pop(tour_actuel)
            print(f">>> [ALERTE] Nouvelles demandes apparues pour les destinations : {nouvelles_destinations} ! <<<")
            for demande in nouvelles_destinations:
                noeud_demand = demande[0]
                quantite = demande[1]
                fenetre = demande[2]
                g.demandes.append(noeud_demand)
                g.noeuds[noeud_demand].requete_presente = True
                g.noeuds[noeud_demand].quantite = quantite
                g.noeuds[noeud_demand].time_window = fenetre
                g.noeuds[noeud_demand].statut = "en_attente"
                g.noeuds[noeud_demand].id_carg = id_carg
                id_carg = id_carg + 1


        # 2. DISPATCHER INTELLIGENT
        for dest in g.demandes:
            camions_libres = [c for c in flotte if not c.route and c.cible_actuelle is None]
            if camions_libres:
                camion_le_plus_proche = min(camions_libres, key=lambda c: distance_entre(g, c.position, dest))
                if camion_le_plus_proche.charge_actuelle >= g.noeuds[dest].quantite :
                    print(f"--> [DISPATCH] Assignation de la demande vers {dest} au {camion_le_plus_proche.id} (le plus proche)")
                    camion_le_plus_proche.assigner_demande(g,dest)
                    camion_le_plus_proche.id_livr_en_cours = g.noeuds[dest].id_carg
                    camion_le_plus_proche.trouver_chemin_vers(dest, g)
                    camion_le_plus_proche.demander(g.noeuds[dest].id_carg, g.noeuds[dest].quantite,"colis")
                    g.demandes.remove(dest)
                else :
                    camions_libres.remove(camion_le_plus_proche)
                
        # Affichage critique : La file d'attente s'allonge !
        if len(g.demandes) != 0:
            print(f"!!! [SURCHARGE] {len(g.demandes)} requêtes en attente : {g.demandes} !!!")
                

        # 3. FAIRE AVANCER LES CAMIONS
        for camion in flotte:
            camion.faire_un_tour(g)
            
        tour_actuel += 1
        
        # On augmente largement la limite de sécurité car les camions vont mettre du temps !
        if tour_actuel > 250: 
            print("Limite de tours atteinte.")
            break
            
    print("\n--- FIN DE LA SIMULATION ---")
