def graphe_exemple():
    # --- 1. CRÉATION DU GRAPHE (Grande ville en grille 4x4) ---
    g = Graphe(oriente=False)
    
    # Création d'un camion
    camion1 = Camion("Camion-01", capacite=20, position_depart=0)
    camion2 = Camion("Camion-02", capacite=20, position_depart=0)
    
    # Ajout de 16 nœuds (A à P)
    noeuds_data = [
        (0, "A", 0, 0),   (1, "B", 5, 0),   (2, "C", 10, 0),  (3, "D", 15, 0),
        (4, "E", 0, 5),   (5, "F", 5, 5),   (6, "G", 10, 5),  (7, "H", 15, 5),
        (8, "I", 0, 10),  (9, "J", 5, 10),  (10, "K", 10, 10),(11, "L", 15, 10),
        (12, "M", 0, 15), (13, "N", 5, 15), (14, "O", 10, 15),(15, "P", 15, 15)
    ]
    
    for id_n, nom, x, y in noeuds_data:
        g.ajouter_noeud(Noeud(id_n, nom, x, y, (0, 0), 100))

    # Ajout automatique des arêtes pour créer la grille
    for i in range(4):
        for j in range(4):
            noeud_actuel = i * 4 + j
            # Routes horizontales (poids = 3)
            if j < 3:
                g.ajouter_arete(noeud_actuel, noeud_actuel + 1, poids=3)
            # Routes verticales (poids = 4)
            if i < 3:
                g.ajouter_arete(noeud_actuel, noeud_actuel + 4, poids=4)
                
    # Quelques rocades rapides (diagonales, poids = 5)
    g.ajouter_arete(5, 10, poids=5)
    g.ajouter_arete(6, 9, poids=5)
    g.ajouter_arete(0, 5, poids=5)
    g.ajouter_arete(10, 15, poids=5)

    # --- 2. CRÉATION DE LA FLOTTE (Seulement 2 camions !) ---
    flotte = [camion1,camion2]

    # --- 3. GESTION DYNAMIQUE DES DEMANDES (Avalanche de requêtes) ---
    demandes_futures = {
        2:  [(2, 3, (2, 8)),  (15, 8, (2, 8))], #(id_du_noeud_client,qte_demander)  # Tour 2 : Les deux extrémités
        5:  [(3, 2, (5, 11)), (12, 2, (5, 11)), (7, 2, (5, 11))], # Tour 5 : 3 requêtes d'un coup
        8:  [(1, 2, (8, 14)), (14, 2, (8, 14)), (2, 2, (8, 14)), (11, 2, (8, 14))], # Tour 8 : Énorme vague de 4 requêtes !
        15: [(4, 2, (15, 21)), (9, 2, (15, 21)), (6, 2, (15, 21)), (8, 2, (15, 21))], # Tour 15 : Encore 4 requêtes
        20: [(5, 2, (20, 26)), (10, 2, (20, 26))] # Tour 20 : Retour au centre
    }

    return g, flotte, demandes_futures

